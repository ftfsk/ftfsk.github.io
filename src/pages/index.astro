---
import Layout from '../layouts/Layout.astro';
import logoSrc from '../assets/logo.png';
import video1 from '../assets/output.mp4';
import portfolioItems from '../data/portfolio-items';
---

<Layout>
  <main class="page-shell">

    <!-- NAVIGATION -->
    <nav class="top-nav" id="top-nav" aria-label="Primary navigation">
      <div class="nav-left">
        <a class="logo-link" href="#home">
          <img class="logo" src={logoSrc.src} alt="Fly Through Films logo" />
        </a>

        <div class="nav-links">
          <a href="#portfolio">
            <span class="nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </span>
            Πόρτφολιο
          </a>
          <a href="#services">
            <span class="nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>
            </span>
            Υπηρεσίες
          </a>
          <a href="#about">
            <span class="nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M5.5 21c1.83-3.36 5.1-5 6.5-5s4.67 1.64 6.5 5"/></svg>
            </span>
            Σχετικά
          </a>
        </div>
      </div>

      <a href="#contact" class="button nav-cta">Επικοινωνία</a>
    </nav>

    <!-- HERO -->
    <section class="hero" id="home">
      <video class="hero-video" autoplay muted loop playsinline poster="/background.svg">
        <source src={video1} type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
      <div class="hero-copy">
        <span class="tag">Fly Through Films</span>
        <h1>
          <span class="keyword" aria-live="polite">Εξατομικευμένες Υπηρεσίες</span>
        </h1>
        <p class="hero-lead">
          Μοναδικό cinematic περιεχόμενο για σκάφη, real estate και events — σχεδιασμένο για premium brands.
        </p>
        <div class="hero-actions">
          <a href="#portfolio" class="button">Προβολή Portfolio</a>
          <a href="#contact" class="button button-secondary">Επικοινωνία</a>
        </div>
      </div>
    </section>

    <!-- WHITE SECTION -->
    <section class="white-hero-section">
      <div class="white-hero-copy">
        <span class="tag light">Δεν φωτογραφίζουμε απλώς...</span>
        <h2>Αποτυπώνουμε τις εικόνες που οι πελάτες μας οραματίζονται.</h2>
        <p>
          Από βίντεο με drones μέχρι branded περιεχόμενο, δημιουργούμε υλικό που αποθεώνει
          premium προϊόντα και κάνει το όραμά σας αδύνατον να προσπεραστεί.
        </p>
      </div>
      <div class="white-hero-media">
        <video class="white-video" autoplay muted loop playsinline poster="/background.svg">
          <source src={video1} type="video/mp4" />
        </video>
      </div>
    </section>

    <!-- DARK CONTENT WRAPPER -->
    <div class="content-bg-wrapper">

      <!-- PORTFOLIO -->
      <section id="portfolio" class="section portfolio-section">
        <div class="section-heading">
          <span class="section-label">Πόρτφολιο</span>
          <h2>Υλικό για σύγχρονες επιχειρήσεις</h2>
        </div>

        <div class="portfolio-scroller" aria-label="Portfolio services">
          <div class="portfolio-track">
            {portfolioItems.map((item) => (
              <article class="card service-card">
                <div class="card-visual" style={`background-image: url('${item.imageUrl}')`} aria-label={item.imageFile}></div>
                <div class="card-copy">
                  <span class="card-category">{item.category}</span>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- SERVICES -->
      <section id="services" class="section section-service-grid">
        <div class="section-heading">
          <span class="section-label">Υπηρεσίες</span>
          <h2>Τι φέρνουμε στο επόμενό σας project</h2>
        </div>
        <div class="services-drone" aria-hidden="true">
          <svg viewBox="0 0 120 80" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <!-- refined drone: central body, camera (gold), four rotors -->
            <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none">
              <!-- arms -->
              <path d="M30 20 L50 30" />
              <path d="M90 20 L70 30" />
              <path d="M30 60 L50 50" />
              <path d="M90 60 L70 50" />

              <!-- rotors -->
              <circle cx="26" cy="18" r="7" />
              <circle cx="94" cy="18" r="7" />
              <circle cx="26" cy="62" r="7" />
              <circle cx="94" cy="62" r="7" />

              <!-- body -->
              <rect x="44" y="28" width="32" height="24" rx="5" />
              <!-- camera / sensor (gold) -->
              <circle cx="60" cy="40" r="5" fill="rgba(232,160,32,0.96)" stroke="none" />

              <!-- subtle trail for motion readibility -->
              <path d="M10 44c20-14 40-16 70-6" opacity="0.12" />
            </g>
          </svg>
        </div>
        <div class="service-grid">
          <div class="service-box">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.9L15 14"/><rect x="1" y="6" width="15" height="12" rx="2"/></svg>
            </div>
            <h3>Aerial Videography</h3>
            <p>Σταθερές cinematic λήψεις για promos, commercials και digital campaigns.</p>
          </div>
          <div class="service-box">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M3 9l2-4h14l2 4v9a1 1 0 01-1 1H4a1 1 0 01-1-1V9z"/></svg>
            </div>
            <h3>Drone Photography</h3>
            <p>Εναέριες φωτογραφίες υψηλής ανάλυσης για print, web και social media.</p>
          </div>
          <div class="service-box">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 4v16M17 4v16M3 8h4m10 0h4M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
            </div>
            <h3>Brand Films</h3>
            <p>Cinematic films με αφηγηματικό χαρακτήρα για premium brand identity.</p>
          </div>
          <div class="service-box">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h3>Event Coverage</h3>
            <p>Ολοκληρωμένη κάλυψη με video και φωτογραφία για κάθε live experience.</p>
          </div>
        </div>
      </section>

      <!-- ABOUT -->
      <section id="about" class="section about-section">
        <div class="about-inner">
          <div class="about-text">
            <span class="section-label">Σχετικά</span>
            <h2>Drone crews φτιαγμένα για visual storytelling</h2>
            <p>
              Συνδυάζουμε επαγγελματικές πτητικές πρακτικές με δημιουργική κατεύθυνση για να παραδώσουμε
              υψηλής ποιότητας εναέριο περιεχόμενο. Από το concept μέχρι το τελικό edit,
              η δουλειά μας είναι προσαρμοσμένη για brands που θέλουν να ξεχωρίζουν.
            </p>
            <ul class="about-list">
              <li>
                <span class="list-dot"></span>
                Επαγγελματίες drone pilots με πιστοποίηση
              </li>
              <li>
                <span class="list-dot"></span>
                Κάμερες 4K και 6K για ανάλυση άλλου επιπέδου
              </li>
              <li>
                <span class="list-dot"></span>
                Γρήγορη παράδοση και εύκολη αδειοδότηση
              </li>
            </ul>
          </div>
          <div class="about-visual"></div>
        </div>
      </section>

      <!-- CONTACT -->
      <section id="contact" class="section contact-section">
        <div class="contact-inner">
          <span class="section-label light">Επικοινωνία</span>
          <h2>Σου άρεσε η δουλειά και η φιλοσοφία μας;</h2>
          <p>
            Μην διστάσεις να επικοινωνήσεις με email ή να μας βρεις στις παρακάτω πλατφόρμες.
          </p>
          <div class="contact-actions">
            <a href="mailto:flythroughfilms@gmail.com" class="button contact-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              flythroughfilms@gmail.com
            </a>
            <div class="contact-social">
              <a href="https://www.instagram.com/yourprofile" target="_blank" rel="noopener noreferrer" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5"/><path d="M16 11.37a4 4 0 1 1-7.99.63A4 4 0 0 1 16 11.37z"/><path d="M17.5 6.5h.01"/></svg>
                <span>Instagram</span>
              </a>
              <a href="https://www.youtube.com/yourchannel" target="_blank" rel="noopener noreferrer" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29.44 29.44 0 0 0 1 12a29.44 29.44 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29.44 29.44 0 0 0 23 12a29.44 29.44 0 0 0-.46-5.58z"/><path d="M10 15l5-3-5-3v6z"/></svg>
                <span>YouTube</span>
              </a>
            </div>
          </div>
        </div>
      </section>

    </div><!-- end .content-bg-wrapper -->

    <!-- FOOTER -->
    <footer class="footer">
      <p>Fly Through Films © 2026 — Cinematic Aerial Media</p>
    </footer>
  </main>

  <script>
    /* ── Keyword cycling ── */
    const keywords = ['Εξατομικευμένες Υπηρεσίες', 'Τέχνη και Επιχείρηση', 'Αύξηση Πωλήσεων', 'Δημιουργία Αναμνήσεων', 'Κάλυψη Εκδηλώσεων', 'Προώθηση Προϊόντων'];
    const keywordEl = document.querySelector<HTMLElement>('.hero-copy .keyword');
    let keywordIndex = 0;

    const updateKeyword = () => {
      if (!keywordEl) return;
      keywordEl.classList.add('fade-out');
      window.setTimeout(() => {
        keywordIndex = (keywordIndex + 1) % keywords.length;
        keywordEl.textContent = keywords[keywordIndex];
        keywordEl.classList.remove('fade-out');
      }, 400);
    };
    if (keywordEl) window.setInterval(updateKeyword, 3000);

    /* ── Nav visibility: show only while hero is in view ── */
    const heroEl = document.querySelector<HTMLElement>('.hero');
    const navEl  = document.querySelector<HTMLElement>('#top-nav');

    if (heroEl && navEl && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            navEl.classList.remove('nav-hidden');
          } else {
            navEl.classList.add('nav-hidden');
          }
        });
      }, { threshold: 0.05 });
      io.observe(heroEl);
    }

    /* ── Portfolio auto-scroll with seamless loop ── */
    (() => {
      const scroller = document.querySelector<HTMLElement>('.portfolio-scroller');
      const track = scroller?.querySelector<HTMLElement>('.portfolio-track');
      if (!scroller || !track) return;

      const items = Array.from(track.children);
      if (items.length === 0) return;

      items.forEach((item) => track.appendChild(item.cloneNode(true)));

      let lastTime = performance.now();
      let paused = false;
      let loopWidth = 0;

      const updateLoopWidth = () => {
        loopWidth = track.scrollWidth / 2;
      };

      const onWheel = (event: WheelEvent) => {
        if (Math.abs(event.deltaY) > 0) {
          event.preventDefault();
          scroller.scrollLeft += event.deltaY * 0.9;
        }
      };

      const onPointerEnter = () => { paused = true; };
      const onPointerLeave = () => { paused = false; };

      const step = (time: number) => {
        if (!paused) {
          const delta = time - lastTime;
          lastTime = time;
          scroller.scrollLeft += (80 * delta) / 1000;
          if (scroller.scrollLeft >= loopWidth) {
            scroller.scrollLeft -= loopWidth;
          }
        } else {
          lastTime = time;
        }
        requestAnimationFrame(step);
      };

      window.addEventListener('resize', updateLoopWidth);
      scroller.addEventListener('mouseenter', onPointerEnter);
      scroller.addEventListener('mouseleave', onPointerLeave);
      scroller.addEventListener('wheel', onWheel, { passive: false });
      updateLoopWidth();
      requestAnimationFrame(step);
    })();
  </script>
</Layout>

<style>
  /* =====================================================
     DESIGN TOKENS
  ===================================================== */
  :root {
    --ink:        #06091A;
    --ink-soft:   #0D1129;
    --surface:    #ffffff;
    --gold:       #E8A020;
    --gold-light: #F5B942;
    --gold-dim:   rgba(232,160,32,0.12);
    --text-light: rgba(248,250,252,0.80);
    --text-muted: rgba(248,250,252,0.48);
    --border:     rgba(255,255,255,0.07);

    /* Typography */
    --font-display: 'Bebas Neue', sans-serif;
    --font-body:    'Lato', ui-sans-serif, system-ui, sans-serif;
    --font-label:   'DM Mono', 'Courier New', monospace;
  }

  /* Google Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lato:wght@300;400;500;600;700&display=swap');

  :global(html, body) {
    margin: 0;
    min-height: 100%;
    font-family: var(--font-body);
    color: var(--ink);
    background: #ffffff;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  :global(body) { overflow-x: hidden; }

  .page-shell {
    position: relative;
    min-height: 100vh;
    z-index: 1;
    width: 100%;
    max-width: 100%;
  }

  /* =====================================================
     NAVIGATION
  ===================================================== */
  .top-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    padding: 0 2.5rem;
    background: linear-gradient(180deg, rgba(6,9,26,0.72) 0%, transparent 100%);
    backdrop-filter: blur(0px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .top-nav.nav-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-100%);
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .logo-link { display: flex; align-items: center; flex-shrink: 0; }
  .logo { height: 48px; width: auto; object-fit: contain; display: block; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(248,250,252,0.88);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .nav-links a:hover { color: #ffffff; }

  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0; bottom: -0.4rem;
    width: 100%; height: 1px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-icon {
    display: inline-flex;
    width: 0.9rem;
    height: 0.9rem;
    opacity: 0.7;
  }

  .nav-cta {
    padding: 0.65rem 1.4rem;
    border-radius: 0.5rem;
    background: var(--gold);
    color: var(--ink) !important;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
    min-width: unset;
    border-radius: 0.5rem;
  }

  .nav-cta:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  /* =====================================================
     HERO
  ===================================================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: calc(80px + 2rem) 1.5rem 5rem;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
    filter: saturate(1.08) contrast(1.12) brightness(1.08);
    pointer-events: none;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(6,9,26,0.18) 0%,
      rgba(6,9,26,0.28) 60%,
      rgba(6,9,26,0.42) 100%
    );
    z-index: 1;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 880px;
    margin: 0 auto;
  }

  .tag {
    display: inline-flex;
    margin-bottom: 1.5rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(248,250,252,0.85);
    font-family: var(--font-label);
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .tag.light {
    background: rgba(6,9,26,0.06);
    border-color: rgba(6,9,26,0.12);
    color: rgba(6,9,26,0.65);
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: #ffffff;
  }

  .hero-copy .keyword {
    display: inline-block;
    color: var(--gold-light);
    font-style: italic;
    transition: opacity 0.4s ease;
  }

  .hero-copy .keyword.fade-out { opacity: 0; }

  .hero-lead {
    max-width: 600px;
    margin: 2rem auto 0;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--text-light);
  }

  .hero-actions {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.75rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 180px;
    padding: 0.95rem 1.75rem;
    border-radius: 0.5rem;
    background: rgba(255,255,255,0.95);
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.88rem;
    letter-spacing: 0.04em;
    transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
    background: #ffffff;
    box-shadow: 0 16px 40px rgba(6,9,26,0.18);
  }

  .button-secondary {
    background: rgba(255,255,255,0.08);
    color: #f8fafc;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .button-secondary:hover {
    background: rgba(255,255,255,0.16);
  }

  /* =====================================================
     WHITE HERO SECTION
  ===================================================== */
  .white-hero-section {
    width: 100%;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 4rem;
    padding: 6rem 6rem;
    background: #ffffff;
    color: var(--ink);
  }

  .white-hero-copy {
    max-width: 460px;
  }

  .white-hero-copy .tag.light {
    margin-bottom: 1.2rem;
    background: transparent;
    border: none;
    color: #06091A;
  }

  .white-hero-copy h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .white-hero-copy p {
    margin: 1.75rem 0 0;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.85;
    color: rgba(6,9,26,0.70);
  }

  .white-hero-media {
    position: relative;
    min-height: 440px;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(6,9,26,0.10);
  }

  .white-video {
    width: 100%;
