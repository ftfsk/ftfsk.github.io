---
import Layout from '../layouts/Layout.astro';
import logoSrc from '../assets/logo.png';
import video1 from '../assets/output.mp4';
---

<Layout>
  <video
    class="page-bg-video"
    autoplay
    muted
    loop
    playsinline
    poster="/background.svg"
  >
    <source
      src={video1}
      type="video/mp4"
    />
  </video>

  <main class="page-shell">
    <!-- NAVIGATION -->
    <nav class="top-nav" aria-label="Primary navigation">
      <a class="logo-link" href="#home">
        <img
          class="logo"
          src={logoSrc.src}
          alt="Brand logo"
        /> 
        
      </a>


      <div class="nav-links">
        <a href="#portfolio">Portfolio</a>
        <a href="#services">Υπηρεσίες</a>
        <a href="#contact">Επικοινωνία</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero" id="home">
      <div class="hero-overlay"></div>

      <div class="hero-copy">
        <span class="tag">Drone Photography</span>

        <h1>
          Δημιούργησε στιγμές μαζί μας
        </h1>

        <p>
		Παραγωγή φωτογραφικού και βιντεογραφικού περιεχομένου υψηλής ποιότητας. Για την επιχείρηση σου, το σκάφος, 
		το real estate, το event και τι στιγμές που ψάχνεις να μεταδόσεις!

        </p>

        <div class="hero-actions">
          <a href="#portfolio" class="button">
            Προβολή Portfolio
          </a>

          <a
            href="#contact"
            class="button button-secondary"
          >
            Επικοινωνία
          </a>
        </div>
      </div>
    </section>

    <!-- VIDEO BACKGROUND WRAPPER -->
    <div class="content-bg-wrapper">
      <!-- PORTFOLIO -->
      <section id="portfolio" class="section panel">
      <div class="section-heading">
        <span>Portfolio</span>
        <h2>Drone imagery for modern brands</h2>
      </div>

      <div class="card-grid">
        <article class="card">
          <div class="card-visual card-visual-1"></div>

          <h3>Coastal Resorts</h3>

          <p>
            Capture immersive aerial scenes that showcase
            location, luxury, and lifestyle from above.
          </p>
        </article>

        <article class="card">
          <div class="card-visual card-visual-2"></div>

          <h3>Real Estate</h3>

          <p>
            Crisp aerial photos and walkthrough videos
            designed to elevate property listings and marketing.
          </p>
        </article>

        <article class="card">
          <div class="card-visual card-visual-3"></div>

          <h3>Adventure & Events</h3>

          <p>
            Dynamic coverage for outdoor experiences,
            festivals, launches, and brand activations.
          </p>
        </article>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="section section-alt">
      <div class="section-heading">
        <span>Services</span>
        <h2>What we bring to your next project</h2>
      </div>

      <div class="feature-grid">
        <div class="feature">
          <h3>Aerial Videography</h3>

          <p>
            Steady cinematic footage for promos,
            commercials, and digital campaigns.
          </p>
        </div>

        <div class="feature">
          <h3>Drone Photography</h3>

          <p>
            Sharp, high-resolution aerial stills ready
            for print, web, and social use.
          </p>
        </div>

        <div class="feature">
          <h3>Inspection & Survey</h3>

          <p>
            Fast and safe aerial inspection imagery for
            construction, land, and event planning.
          </p>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="section panel">
      <div class="split-layout">
        <div>
          <span>About</span>

          <h2>
            Drone crews built for visual storytelling
          </h2>

          <p>
            We combine FAA-safe flight practices with
            creative direction to deliver polished aerial media.
            From concept through final edit, our work is tailored
            for brands that need next-level perspective.
          </p>

          <ul>
            <li>Professional drone pilots</li>
            <li>4K and 6K camera systems</li>
            <li>Fast delivery and easy licensing</li>
          </ul>
        </div>

        <div class="about-visual"></div>
      </div>
    </section>

    <!-- CONTACT -->
    <section
      id="contact"
      class="section section-alt contact-panel"
    >
      <div>
        <span>Contact</span>

        <h2>
          Ready to launch your next aerial campaign?
        </h2>

        <p>
          Reach out for a custom quote, location scouting,
          or creative direction for your next drone shoot.
        </p>

        <a
          href="mailto:hello@droneportfolio.com"
          class="button"
        >
          hello@droneportfolio.com
        </a>
      </div>
    </section>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
      <p>
        Drone Portfolio • Cinematic Aerial Photography &
        Video • © 2026
      </p>
    </footer>
  </main>
</Layout>

<style>
  :global(html, body) {
    margin: 0;
    min-height: 100%;

    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      sans-serif;

    color: #f8fafc;
    background: transparent;
  }

  :global(body) {
    overflow-x: hidden;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    z-index: 1;
  }

  /* =========================
     PAGE BG VIDEO
  ========================== */

  .page-bg-video {
    position: fixed;
    top: 0;
    left: 0;

    width: 100%;
    height: 100vh;

    object-fit: cover;

    opacity: 0.6;

    filter:
      saturate(0.95)
      contrast(1.05);

    pointer-events: none;

    z-index: 0;
  }

  /* =========================
     DJI-STYLE NAVBAR
  ========================== */

  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;

    z-index: 100;

    display: flex;
    align-items: center;
    justify-content: space-between;

    height: 82px;
    padding: 0 2.5rem;

    background: rgba(5, 8, 22, 0.72);

    backdrop-filter: blur(18px);

    border-bottom:
      1px solid rgba(255, 255, 255, 0.06);
  }

  .logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo {
    height: 52px;
    width: auto;

    object-fit: contain;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;

    gap: 2.2rem;
  }

  .nav-links a {
    position: relative;

    color: rgba(255, 255, 255, 0.78);

    text-decoration: none;

    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: 0.01em;

    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .nav-links a:hover {
    color: #ffffff;
  }

  .nav-links a::after {
    content: '';

    position: absolute;
    left: 0;
    bottom: -0.45rem;

    width: 100%;
    height: 1px;

    background: white;

    transform: scaleX(0);
    transform-origin: center;

    transition: transform 0.25s ease;
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  /* =========================
     HERO
  ========================== */

  .hero {
    position: relative;

    min-height: 100vh;

    display: grid;
    place-items: center;

    text-align: center;

    padding:
      calc(82px + 2rem)
      1.5rem
      2rem;

    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;

    background:
      linear-gradient(
        180deg,
        rgba(5, 8, 22, 0.32),
        rgba(5, 8, 22, 0.84)
      );
  }

  .hero-copy {
    position: relative;
    z-index: 1;

    max-width: 840px;
  }

  .tag {
    display: inline-flex;

    margin-bottom: 1rem;
    padding: 0.65rem 1rem;

    border-radius: 999px;

    background:
      rgba(255, 255, 255, 0.08);

    color: #dbeafe;

    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;

    font-size: clamp(3rem, 6vw, 5rem);

    line-height: 0.98;
    letter-spacing: -0.05em;

    font-weight: 700;
  }

  p {
    max-width: 720px;

    margin: 1.5rem auto 0;

    font-size: 1.05rem;
    line-height: 1.75;

    color:
      rgba(248, 250, 252, 0.84);
  }

  .hero-actions {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;

    gap: 1rem;

    margin-top: 2.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    min-width: 170px;

    padding: 0.95rem 1.5rem;

    border-radius: 999px;

    background: white;
    color: #050816;

    text-decoration: none;
    font-weight: 600;

    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
    background: #e5e7eb;
  }

  .button-secondary {
    background:
      rgba(255, 255, 255, 0.1);

    color: white;

    border:
      1px solid rgba(255, 255, 255, 0.12);
  }

  .button-secondary:hover {
    background:
      rgba(255, 255, 255, 0.18);
  }

  /* =========================
     SECTIONS
  ========================== */

  .section {
    max-width: 1200px;

    margin: 0 auto;
    padding: 6rem 1.5rem;

    position: relative;
    z-index: 1;

    background: #050816;
  }

  .section-alt {
    background: #070b1d;
  }

  .section-heading {
    max-width: 680px;
    margin-bottom: 2.5rem;
  }

  .section-heading span {
    display: inline-block;

    margin-bottom: 0.9rem;

    color: #94a3b8;

    text-transform: uppercase;
    letter-spacing: 0.18em;

    font-size: 0.78rem;
  }

  .section-heading h2 {
    margin: 0;

    font-size:
      clamp(2rem, 2.4vw, 3rem);

    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  /* =========================
     CARDS
  ========================== */

  .card-grid,
  .feature-grid {
    display: grid;
    gap: 1.5rem;
  }

  .card-grid {
    grid-template-columns:
      repeat(3, minmax(0, 1fr));
  }

  .card {
    background:
      rgba(15, 23, 42, 0.82);

    border:
      1px solid rgba(255, 255, 255, 0.06);

    border-radius: 1.5rem;

    padding: 1.4rem;

    transition:
      transform 0.25s ease,
      border-color 0.25s ease;
  }

  .card:hover {
    transform: translateY(-4px);

    border-color:
      rgba(255, 255, 255, 0.14);
  }

  .card h3 {
    margin: 1.2rem 0 0.7rem;

    font-size: 1.2rem;
  }

  .card p {
    margin: 0;

    color:
      rgba(248, 250, 252, 0.74);
  }

  .card-visual {
    width: 100%;
    height: 240px;

    border-radius: 1.2rem;

    background-size: cover;
    background-position: center;
  }

  .card-visual-1 {
    background-image:
      url('https://images.unsplash.com/photo-1500534623283-312aade485b7?auto=format&fit=crop&w=900&q=80');
  }

  .card-visual-2 {
    background-image:
      url('https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=900&q=80');
  }

  .card-visual-3 {
    background-image:
      url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=900&q=80');
  }

  /* =========================
     FEATURES
  ========================== */

  .feature-grid {
    grid-template-columns:
      repeat(3, minmax(0, 1fr));
  }

  .feature {
    background:
      rgba(15, 23, 42, 0.9);

    border-radius: 1.4rem;

    padding: 2rem;

    border:
      1px solid rgba(255, 255, 255, 0.06);
  }

  .feature h3 {
    margin-top: 0;

    font-size: 1.15rem;
  }

  /* =========================
     ABOUT
  ========================== */

  .split-layout {
    display: grid;

    grid-template-columns:
      1.05fr 0.95fr;

    gap: 2rem;
    align-items: center;
  }

  .split-layout ul {
    list-style: none;

    padding: 0;
    margin: 2rem 0 0;

    display: grid;
    gap: 0.85rem;
  }

  .split-layout li {
    position: relative;

    padding-left: 1.2rem;

    color:
      rgba(248, 250, 252, 0.82);
  }

  .split-layout li::before {
    content: '•';

    position: absolute;
    left: 0;

    color: white;
  }

  .about-visual {
    min-height: 420px;

    border-radius: 2rem;

    background-image:
      url('https://images.unsplash.com/photo-1487505984009-0156a0d0b9ef?auto=format&fit=crop&w=1100&q=80');

    background-size: cover;
    background-position: center;

    box-shadow:
      inset 0 0 0 1px
      rgba(255, 255, 255, 0.04);
  }

  /* =========================
     CONTACT
  ========================== */

  .contact-panel {
    display: flex;
    align-items: center;
    justify-content: center;

    text-align: center;

    min-height: 320px;
  }

  .contact-panel h2 {
    margin: 1rem 0 0.8rem;
  }

  /* =========================
     FOOTER
  ========================== */

  .footer {
    padding: 2rem 1.5rem;

    text-align: center;

    color:
      rgba(248, 250, 252, 0.52);
  }

  /* =========================
     RESPONSIVE
  ========================== */

  @media (max-width: 900px) {
    .card-grid,
    .feature-grid,
    .split-layout {
      grid-template-columns: 1fr;
    }

    .hero {
      padding:
        calc(82px + 2rem)
        1rem
        4rem;
    }
  }

  @media (max-width: 768px) {
    .top-nav {
      height: 72px;
      padding: 0 1.2rem;
    }

    .logo {
      height: 44px;
    }

    .nav-links {
      gap: 1rem;
    }

    .nav-links a {
      font-size: 0.82rem;
    }
  }

  @media (max-width: 640px) {
    .top-nav {
      justify-content: center;
    }

    .nav-links {
      display: none;
    }

    .logo-link {
      position: absolute;
      left: 1rem;
    }

    .hero h1 {
      font-size: 2.8rem;
    }

    .card-visual,
    .about-visual {
      height: 260px;
    }
  }
</style>